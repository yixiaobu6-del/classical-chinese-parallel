[
  {
    "id": "lunyu_001",
    "classical": "学而时习之，不亦说乎？",
    "modern": "学习了知识然后按时温习，不是很愉快吗？",
    "source": "论语·学而",
    "dynasty": "春秋",
    "difficulty": "初级",
    "genre": "经",
    "keywords": ["学习", "快乐", "温习"],
    "notes": "\"说\"通\"悦\"，意为喜悦、愉快。"
  },
  {
    "id": "lunyu_002",
    "classical": "有朋自远方来，不亦乐乎？",
    "modern": "有志同道合的朋友从远方来，不是很令人高兴吗？",
    "source": "论语·学而",
    "dynasty": "春秋",
    "difficulty": "初级",
    "genre": "经",
    "keywords": ["朋友", "快乐", "交友"],
    "notes": ""
  },
  {
    "id": "lunyu_003",
    "classical": "人不知而不愠，不亦君子乎？",
    "modern": "别人不了解自己，自己却不生气，这不就是君子吗？",
    "source": "论语·学而",
    "dynasty": "春秋",
    "difficulty": "中级",
    "genre": "经",
    "keywords": ["修养", "君子", "宽容"],
    "notes": "\"愠\"意为生气、恼怒。"
  },
  {
    "id": "lunyu_004",
    "classical": "温故而知新，可以为师矣。",
    "modern": "温习旧知识从而获得新的理解和体会，就可以做老师了。",
    "source": "论语·为政",
    "dynasty": "春秋",
    "difficulty": "初级",
    "genre": "经",
    "keywords": ["学习", "温故知新", "教学"],
    "notes": ""
  },
  {
    "id": "lunyu_005",
    "classical": "学而不思则罔，思而不学则殆。",
    "modern": "只学习不思考就会迷惑不解，只思考不学习就会陷入困境。",
    "source": "论语·为政",
    "dynasty": "春秋",
    "difficulty": "中级",
    "genre": "经",
    "keywords": ["学习", "思考", "方法"],
    "notes": "\"罔\"意为迷惑；\"殆\"意为危险、困境。"
  },
  {
    "id": "lunyu_006",
    "classical": "三人行，必有我师焉。择其善者而从之，其不善者而改之。",
    "modern": "几个人一起行走，其中一定有可以做我老师的人。选择他们的优点学习，看到他们的缺点就反省自己并改正。",
    "source": "论语·述而",
    "dynasty": "春秋",
    "difficulty": "中级",
    "genre": "经",
    "keywords": ["学习", "谦虚", "自省"],
    "notes": ""
  },
  {
    "id": "lunyu_007",
    "classical": "知之为知之，不知为不知，是知也。",
    "modern": "知道就是知道，不知道就是不知道，这才是真正的智慧。",
    "source": "论语·为政",
    "dynasty": "春秋",
    "difficulty": "初级",
    "genre": "经",
    "keywords": ["诚实", "学习", "智慧"],
    "notes": "最后一个\"知\"通\"智\"，意为智慧。"
  },
  {
    "id": "lunyu_008",
    "classical": "己所不欲，勿施于人。",
    "modern": "自己不愿意做的事情，不要强加给别人。",
    "source": "论语·卫灵公",
    "dynasty": "春秋",
    "difficulty": "初级",
    "genre": "经",
    "keywords": ["仁爱", "伦理", "待人"],
    "notes": ""
  },
  {
    "id": "mengzi_001",
    "classical": "天将降大任于是人也，必先苦其心志，劳其筋骨，饿其体肤，空乏其身，行拂乱其所为。",
    "modern": "上天要把重大使命降临给这个人时，必定先使他的内心痛苦，使他的筋骨劳累，使他经受饥饿，使他身受贫困，使他做事受到阻挠。",
    "source": "孟子·告子下",
    "dynasty": "战国",
    "difficulty": "中级",
    "genre": "经",
    "keywords": ["磨难", "励志", "成长"],
    "notes": ""
  },
  {
    "id": "mengzi_002",
    "classical": "生于忧患，死于安乐。",
    "modern": "忧患使人生存发展，安逸享乐使人萎靡死亡。",
    "source": "孟子·告子下",
    "dynasty": "战国",
    "difficulty": "初级",
    "genre": "经",
    "keywords": ["忧患", "安乐", "哲理"],
    "notes": ""
  },
  {
    "id": "mengzi_003",
    "classical": "老吾老以及人之老，幼吾幼以及人之幼。",
    "modern": "尊敬自己的长辈，从而推广到尊敬别人的长辈；爱护自己的孩子，从而推广到爱护别人的孩子。",
    "source": "孟子·梁惠王上",
    "dynasty": "战国",
    "difficulty": "中级",
    "genre": "经",
    "keywords": ["仁爱", "推己及人", "伦理"],
    "notes": ""
  },
  {
    "id": "mengzi_004",
    "classical": "鱼，我所欲也；熊掌，亦我所欲也。二者不可得兼，舍鱼而取熊掌者也。",
    "modern": "鱼是我想要的，熊掌也是我想要的。如果两者不能同时得到，就舍弃鱼而选择熊掌。",
    "source": "孟子·告子上",
    "dynasty": "战国",
    "difficulty": "初级",
    "genre": "经",
    "keywords": ["选择", "取舍", "比喻"],
    "notes": ""
  },
  {
    "id": "mengzi_005",
    "classical": "富贵不能淫，贫贱不能移，威武不能屈，此之谓大丈夫。",
    "modern": "富贵不能使他迷惑，贫贱不能使他动摇，威武不能使他屈服，这才叫作大丈夫。",
    "source": "孟子·滕文公下",
    "dynasty": "战国",
    "difficulty": "中级",
    "genre": "经",
    "keywords": ["气节", "大丈夫", "品德"],
    "notes": ""
  },
  {
    "id": "zhuangzi_001",
    "classical": "北冥有鱼，其名为鲲。鲲之大，不知其几千里也。",
    "modern": "北海有一条鱼，它的名字叫鲲。鲲的巨大，不知道有几千里。",
    "source": "庄子·逍遥游",
    "dynasty": "战国",
    "difficulty": "初级",
    "genre": "子",
    "keywords": ["庄子", "想象", "逍遥"],
    "notes": ""
  },
  {
    "id": "zhuangzi_002",
    "classical": "化而为鸟，其名为鹏。鹏之背，不知其几千里也。",
    "modern": "它变化为鸟，名字叫鹏。鹏的脊背，不知道有几千里。",
    "source": "庄子·逍遥游",
    "dynasty": "战国",
    "difficulty": "初级",
    "genre": "子",
    "keywords": ["庄子", "变化", "想象"],
    "notes": ""
  },
  {
    "id": "zhuangzi_003",
    "classical": "怒而飞，其翼若垂天之云。",
    "modern": "它振翅奋飞，翅膀就像天边垂下的云彩。",
    "source": "庄子·逍遥游",
    "dynasty": "战国",
    "difficulty": "中级",
    "genre": "子",
    "keywords": ["庄子", "气势", "飞翔"],
    "notes": ""
  },
  {
    "id": "zhuangzi_004",
    "classical": "子非鱼，安知鱼之乐？",
    "modern": "你又不是鱼，怎么知道鱼的快乐呢？",
    "source": "庄子·秋水",
    "dynasty": "战国",
    "difficulty": "初级",
    "genre": "子",
    "keywords": ["庄子", "辩论", "认知"],
    "notes": "庄子与惠子濠梁之辩的经典命题。"
  },
  {
    "id": "laozi_001",
    "classical": "道可道，非常道；名可名，非常名。",
    "modern": "可以用语言表述的道，就不是永恒的道；可以用语言命名的名，就不是永恒的名。",
    "source": "老子·第一章",
    "dynasty": "春秋",
    "difficulty": "高级",
    "genre": "子",
    "keywords": ["老子", "道", "哲学"],
    "notes": "老子哲学的核心命题，\"道\"是宇宙本原。"
  },
  {
    "id": "laozi_002",
    "classical": "上善若水。水善利万物而不争。",
    "modern": "最高的善就像水一样。水善于滋润万物而不与万物相争。",
    "source": "老子·第八章",
    "dynasty": "春秋",
    "difficulty": "中级",
    "genre": "子",
    "keywords": ["老子", "水", "不争"],
    "notes": ""
  },
  {
    "id": "laozi_003",
    "classical": "千里之行，始于足下。",
    "modern": "千里的远行，从脚下第一步开始。",
    "source": "老子·第六十四章",
    "dynasty": "春秋",
    "difficulty": "初级",
    "genre": "子",
    "keywords": ["老子", "行动", "积累"],
    "notes": ""
  },
  {
    "id": "laozi_004",
    "classical": "祸兮福之所倚，福兮祸之所伏。",
    "modern": "灾祸啊，幸福正依傍在它旁边；幸福啊，灾祸正潜伏在它里面。",
    "source": "老子·第五十八章",
    "dynasty": "春秋",
    "difficulty": "中级",
    "genre": "子",
    "keywords": ["老子", "祸福", "辩证法"],
    "notes": ""
  },
  {
    "id": "shiji_001",
    "classical": "项庄拔剑起舞，项伯亦拔剑起舞，常以身翼蔽沛公，庄不得击。",
    "modern": "项庄拔出剑开始起舞，项伯也拔出剑起舞，常常用自己的身体像翅膀一样掩护沛公，项庄无法攻击。",
    "source": "史记·项羽本纪",
    "dynasty": "汉",
    "difficulty": "中级",
    "genre": "史",
    "keywords": ["鸿门宴", "项羽", "刘邦"],
    "notes": "描写鸿门宴上\"项庄舞剑，意在沛公\"的紧张场面。"
  },
  {
    "id": "shiji_002",
    "classical": "燕雀安知鸿鹄之志哉！",
    "modern": "燕子和麻雀怎么能知道天鹅的志向呢！",
    "source": "史记·陈涉世家",
    "dynasty": "汉",
    "difficulty": "初级",
    "genre": "史",
    "keywords": ["志向", "陈胜", "比喻"],
    "notes": ""
  },
  {
    "id": "shiji_003",
    "classical": "桃李不言，下自成蹊。",
    "modern": "桃树李树不会说话，但树下自然被走出一条小路。",
    "source": "史记·李将军列传",
    "dynasty": "汉",
    "difficulty": "中级",
    "genre": "史",
    "keywords": ["品德", "感召", "比喻"],
    "notes": "比喻品德高尚的人自然受人景仰。"
  },
  {
    "id": "shiji_004",
    "classical": "王侯将相宁有种乎？",
    "modern": "王侯将相难道是天生的贵种吗？",
    "source": "史记·陈涉世家",
    "dynasty": "汉",
    "difficulty": "初级",
    "genre": "史",
    "keywords": ["平等", "反抗", "陈胜"],
    "notes": "陈胜起义时的著名口号。"
  },
  {
    "id": "zhanguoce_001",
    "classical": "狡兔有三窟，仅得免其死耳。",
    "modern": "狡猾的兔子有三个洞穴，才能免除一死罢了。",
    "source": "战国策·齐策四",
    "dynasty": "西汉",
    "difficulty": "中级",
    "genre": "史",
    "keywords": ["策略", "准备", "安全"],
    "notes": "\"狡兔三窟\"的出处，比喻多留退路。"
  },
  {
    "id": "zhanguoce_002",
    "classical": "士为知己者死，女为悦己者容。",
    "modern": "士人愿意为赏识自己的人献出生命，女子愿意为喜欢自己的人打扮。",
    "source": "战国策·赵策一",
    "dynasty": "西汉",
    "difficulty": "中级",
    "genre": "史",
    "keywords": ["知己", "忠诚", "情感"],
    "notes": ""
  },
  {
    "id": "sunzi_001",
    "classical": "知己知彼，百战不殆。",
    "modern": "了解自己也了解对方，打一百次仗都不会危险。",
    "source": "孙子·谋攻篇",
    "dynasty": "春秋",
    "difficulty": "初级",
    "genre": "子",
    "keywords": ["军事", "智慧", "策略"],
    "notes": ""
  },
  {
    "id": "sunzi_002",
    "classical": "兵者，诡道也。故能而示之不能，用而示之不用。",
    "modern": "用兵是一种诡诈之术。所以能打却装作不能打，要打却装作不想打。",
    "source": "孙子·计篇",
    "dynasty": "春秋",
    "difficulty": "中级",
    "genre": "子",
    "keywords": ["军事", "谋略", "诡道"],
    "notes": ""
  },
  {
    "id": "caocao_001",
    "classical": "对酒当歌，人生几何！譬如朝露，去日苦多。",
    "modern": "对着美酒应当高歌，人生能有多少时光！就像早晨的露水，逝去的日子苦于太多。",
    "source": "短歌行",
    "dynasty": "汉",
    "difficulty": "中级",
    "genre": "集",
    "keywords": ["曹操", "人生", "感慨"],
    "notes": ""
  },
  {
    "id": "chuci_001",
    "classical": "路漫漫其修远兮，吾将上下而求索。",
    "modern": "前方的道路又远又长，我将不遗余力地上下探索追求。",
    "source": "离骚",
    "dynasty": "战国",
    "difficulty": "中级",
    "genre": "集",
    "keywords": ["屈原", "追求", "理想"],
    "notes": ""
  },
  {
    "id": "yueyanglou_001",
    "classical": "先天下之忧而忧，后天下之乐而乐。",
    "modern": "在天下人忧愁之前先忧愁，在天下人快乐之后才快乐。",
    "source": "岳阳楼记",
    "dynasty": "宋",
    "difficulty": "中级",
    "genre": "集",
    "keywords": ["范仲淹", "忧国忧民", "胸怀"],
    "notes": ""
  },
  {
    "id": "yueyanglou_002",
    "classical": "不以物喜，不以己悲。",
    "modern": "不因外物好坏和自己的得失而感到欢喜或悲伤。",
    "source": "岳阳楼记",
    "dynasty": "宋",
    "difficulty": "中级",
    "genre": "集",
    "keywords": ["范仲淹", "修养", "豁达"],
    "notes": ""
  },
  {
    "id": "chushibiao_001",
    "classical": "鞠躬尽瘁，死而后已。",
    "modern": "勤勤恳恳，竭尽全力，到死才停止。",
    "source": "后出师表",
    "dynasty": "三国",
    "difficulty": "初级",
    "genre": "集",
    "keywords": ["诸葛亮", "忠诚", "奉献"],
    "notes": ""
  },
  {
    "id": "taohuayuanji_001",
    "classical": "忽逢桃花林，夹岸数百步，中无杂树，芳草鲜美，落英缤纷。",
    "modern": "忽然遇到一片桃花林，两岸几百步内，中间没有别的树，芳香的青草鲜嫩美丽，落花繁多。",
    "source": "桃花源记",
    "dynasty": "晋",
    "difficulty": "中级",
    "genre": "集",
    "keywords": ["陶渊明", "桃花源", "理想国"],
    "notes": ""
  },
  {
    "id": "taohuayuanji_002",
    "classical": "问今是何世，乃不知有汉，无论魏晋。",
    "modern": "他们问现在是什么朝代，竟然不知道有过汉朝，更不必说魏晋了。",
    "source": "桃花源记",
    "dynasty": "晋",
    "difficulty": "初级",
    "genre": "集",
    "keywords": ["陶渊明", "避世", "隔绝"],
    "notes": ""
  },
  {
    "id": "ailian_001",
    "classical": "出淤泥而不染，濯清涟而不妖。",
    "modern": "从淤泥中生长出来却不沾染污秽，经过清水的洗涤却不显得妖艳。",
    "source": "爱莲说",
    "dynasty": "宋",
    "difficulty": "初级",
    "genre": "集",
    "keywords": ["周敦颐", "莲花", "高洁"],
    "notes": ""
  },
  {
    "id": "jushe_001",
    "classical": "天行健，君子以自强不息。",
    "modern": "天的运行刚健有力，君子应效法天道，自强不息。",
    "source": "周易·乾卦",
    "dynasty": "周",
    "difficulty": "高级",
    "genre": "经",
    "keywords": ["周易", "自强", "哲理"],
    "notes": ""
  },
  {
    "id": "jushe_002",
    "classical": "地势坤，君子以厚德载物。",
    "modern": "大地的气势宽厚和顺，君子应效法大地，以深厚的德行承载万物。",
    "source": "周易·坤卦",
    "dynasty": "周",
    "difficulty": "高级",
    "genre": "经",
    "keywords": ["周易", "厚德", "包容"],
    "notes": ""
  },
  {
    "id": "liubei_001",
    "classical": "勿以恶小而为之，勿以善小而不为。",
    "modern": "不要因为坏事很小就去做，不要因为好事很小就不去做。",
    "source": "三国志·蜀书·先主传",
    "dynasty": "三国",
    "difficulty": "初级",
    "genre": "史",
    "keywords": ["刘备", "品德", "教育"],
    "notes": "刘备给儿子刘禅的遗诏中的话。"
  },
  {
    "id": "guyuanxing_001",
    "classical": "盛年不重来，一日难再晨。及时当勉励，岁月不待人。",
    "modern": "壮年不会重来，一天不会有两个早晨。应当及时努力，岁月不等人。",
    "source": "杂诗",
    "dynasty": "晋",
    "difficulty": "初级",
    "genre": "集",
    "keywords": ["陶渊明", "惜时", "劝学"],
    "notes": ""
  }
]